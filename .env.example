# Canopy Environment Variables
# Copy this file to .env and fill in your keys.
# .env is gitignored — never commit it.

# TMDB — https://www.themoviedb.org/settings/api
EXPO_PUBLIC_TMDB_API_KEY=

# OMDB — https://www.omdbapi.com/apikey.aspx
EXPO_PUBLIC_OMDB_API_KEY=

# IGDB — https://dev.twitch.tv/console
# Requires a Twitch Client ID and a Bearer token via client credentials flow.
EXPO_PUBLIC_IGDB_CLIENT_ID=
EXPO_PUBLIC_IGDB_ACCESS_TOKEN=

# Hardcover — https://hardcover.app/account/api
EXPO_PUBLIC_HARDCOVER_TOKEN=
